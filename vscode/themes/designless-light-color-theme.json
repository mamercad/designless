    "terminal.ansiBrightBlue": "#1A6ACC",
    "terminal.ansiBrightCyan": "#008A8A",
    "terminal.ansiBrightGreen": "#2A8A50",
    "terminal.ansiBrightMagenta": "#7A40C0",
    "terminal.ansiBrightRed": "#E8001A",
    "terminal.ansiBrightWhite": "#6B6560",
    "terminal.ansiBrightYellow": "#9A5E00",
    "terminal.ansiCyan": "#006E6E",
    "terminal.ansiGreen": "#1E6B3C",
    "terminal.ansiMagenta": "#5A2D9A",
    "terminal.ansiRed": "#C0000A",
    "terminal.ansiWhite": "#3A3530",
    "terminal.ansiYellow": "#7A4A00",
    "terminal.background": "#FFFFFF",
    "terminal.foreground": "#111111",
    "terminal.selectionBackground": "#E8E4DF",
    "terminalCursor.background": "#FFFFFF",
    "terminalCursor.foreground": "#FF4719",
    "titleBar.activeBackground": "#FFFFFF",
    "titleBar.activeForeground": "#111111",
    "titleBar.border": "#E8E4DF",
    "titleBar.inactiveBackground": "#FFFFFF",
    "titleBar.inactiveForeground": "#6B6560",
    "tree.indentGuidesStroke": "#E8E4DF"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "comment": "#6B6560",
    "enumMember": "#1050A0",
    "function": "#111111",
    "keyword": "#7A4A00",
    "macro": "#5A2D9A",
    "method": "#111111",
    "namespace": "#3A3530",
    "number": "#C0000A",
    "operator": "#3A3530",
    "parameter": "#111111",
    "property": "#111111",
    "regexp": "#006E6E",
    "string": "#1E6B3C",
    "type": "#1050A0",
    "typeParameter": "#5A2D9A",
    "variable": "#111111",
    "variable.constant": "#C0000A",
    "variable.defaultLibrary": "#5A2D9A",
    "variable.readonly": "#7A4A00"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B6560",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#1E6B3C"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#C0000A"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#7A4A00"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#1050A0"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#5A2D9A"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#3A3530"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C0000A",
        "fontStyle": "underline"
      }
    }
  ]
}