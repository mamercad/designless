    "terminal.ansiGreen": "#5AB87A",
    "terminal.ansiMagenta": "#9575CD",
    "terminal.ansiRed": "#D71921",
    "terminal.ansiWhite": "#E5DDD0",
    "terminal.ansiYellow": "#E8A030",
    "terminal.background": "#090807",
    "terminal.foreground": "#E5DDD0",
    "terminal.selectionBackground": "#1D1A17",
    "terminalCursor.background": "#090807",
    "terminalCursor.foreground": "#FF4719",
    "titleBar.activeBackground": "#090807",
    "titleBar.activeForeground": "#E5DDD0",
    "titleBar.border": "#3A3632",
    "titleBar.inactiveBackground": "#090807",
    "titleBar.inactiveForeground": "#5A5248",
    "tree.indentGuidesStroke": "#25211D"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "comment": "#5A5248",
    "enumMember": "#4A8FD9",
    "function": "#E5DDD0",
    "keyword": "#E8A030",
    "macro": "#9575CD",
    "method": "#E5DDD0",
    "namespace": "#E5DDD0",
    "number": "#D71921",
    "operator": "#E5DDD0",
    "parameter": "#E5DDD0",
    "property": "#E5DDD0",
    "regexp": "#26C6C6",
    "string": "#5AB87A",
    "type": "#4A8FD9",
    "typeParameter": "#9575CD",
    "variable": "#E5DDD0",
    "variable.constant": "#FF3B3B",
    "variable.defaultLibrary": "#B39DDB",
    "variable.readonly": "#E8A030"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5A5248",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#5AB87A"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#D71921"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#E8A030"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#4A8FD9"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#E5DDD0"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#E5DDD0"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9575CD"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#E5DDD0"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF3B3B",
        "fontStyle": "underline"
      }
    }
  ]
}